{
    "name": "caretrack-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run frontend-dev\" \"npm run backend-start\"",
        "frontend-dev": "cd frontend && npm run dev",
        "frontend-build": "cd frontend && npm run build",
        "backend-dev": "cd backend && npm run dev",
        "backend-start": "cd backend && npm start"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}